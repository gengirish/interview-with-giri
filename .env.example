# -- Database --
POSTGRES_DB=interviewbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/interviewbot

# -- Redis --
REDIS_URL=redis://localhost:6379

# -- Auth --
JWT_SECRET=                         # REQUIRED: openssl rand -hex 32

# -- AI Services --
BONSAI_API_KEY=                     # FREE at https://trybons.ai (recommended for dev)
BONSAI_BASE_URL=https://api.trybons.ai/v1
OPENAI_API_KEY=                     # Optional (or use Bonsai instead)
ANTHROPIC_API_KEY=                  # Optional fallback
ELEVENLABS_API_KEY=                 # Required for voice interviews

# -- LiveKit --
LIVEKIT_API_KEY=                    # Required for voice/video
LIVEKIT_API_SECRET=                 # Required for voice/video
LIVEKIT_URL=ws://localhost:7880

# -- Stripe --
STRIPE_SECRET_KEY=                  # Required for billing
STRIPE_WEBHOOK_SECRET=              # Required for billing
NEXT_PUBLIC_STRIPE_KEY=             # Stripe publishable key

# -- Code Execution --
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# -- Storage --
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=interviewbot-media

# -- Email --
SMTP_HOST=                          # e.g., smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@interviewbot.ai

# -- App --
APP_ENV=dev
DEBUG=true
APP_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# -- Frontend --
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8001
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
